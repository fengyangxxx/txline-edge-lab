{
  "name": "txline-edge-lab",
  "version": "0.1.0",
  "description": "CLI and browser MVP for a TxLINE odds/scores trading-signal agent.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "txline-edge-lab": "./bin/txline-edge-lab.mjs"
  },
  "files": [
    "artifacts/live-contract-check.json",
    "artifacts/submission-packet.json",
    "bin",
    "docs",
    "index.html",
    "src",
    "scripts",
    "LICENSE",
    "README.md",
    "vite.config.js"
  ],
  "keywords": [
    "txline",
    "txodds",
    "trading-agent",
    "sports-odds",
    "solana",
    "hackathon"
  ],
  "homepage": "https://fengyangxxx.github.io/txline-edge-lab/",
  "repository": {
    "type": "git",
    "url": "https://github.com/fengyangxxx/txline-edge-lab.git"
  },
  "scripts": {
    "attest": "node scripts/proof-envelope.mjs",
    "cli": "node bin/txline-edge-lab.mjs replay --json",
